// =============================================================================
// eventhouse-schema.kql
// External table declarations for the KQL Database in Fabric Eventhouse.
//
// These tables point at OneLake shortcuts in the Bronze Lakehouse intermediary
// (ADR-001). Do NOT point shortcuts directly at the Mirrored Database — the
// Query Acceleration engine will return a 401 on _delta_log.
//
// How to use:
//   1. Open your KQL Database in Fabric.
//   2. Click "Explore your data" → open the query editor.
//   3. Replace <workspace-id> and <bronze-lakehouse-id> with your actual IDs
//      (find them in the OneLake path shown in the lakehouse properties).
//   4. Run this script to register all external tables.
//
// After registering, query with:  external_table('SensorReadings') | take 10
// =============================================================================

// ── Variables — set these before running ─────────────────────────────────────
// Replace with your actual workspace and lakehouse IDs.
let workspace_id    = "<your-workspace-id>";
let lakehouse_id    = "<your-bronze-lakehouse-id>";

// Base ABFS path for all tables
// Shortcut tables land in Tables/<TableName> in the lakehouse
// =============================================================================

// SensorReadings ──────────────────────────────────────────────────────────────
.create-or-alter external table SensorReadings (
    reading_id  : long,
    sensor_id   : int,
    ts          : datetime,
    value       : real,
    quality     : int
)
kind = delta
(
    h@"abfss://<your-workspace-id>@onelake.dfs.fabric.microsoft.com/<your-bronze-lakehouse-id>/Tables/SensorReadings"
)
with
(
    docstring = "High-frequency LP Gas plant sensor telemetry (one row per tag per 5 s)",
    folder    = "Bronze"
)

// Alarms ──────────────────────────────────────────────────────────────────────
.create-or-alter external table Alarms (
    alarm_id     : int,
    sensor_id    : int,
    alarm_type   : string,
    alarm_value  : real,
    alarm_time   : datetime,
    acknowledged : bool,
    ack_time     : datetime,
    ack_by       : string
)
kind = delta
(
    h@"abfss://<your-workspace-id>@onelake.dfs.fabric.microsoft.com/<your-bronze-lakehouse-id>/Tables/Alarms"
)
with
(
    docstring = "ISA-18.2 threshold breach alarm events (H, HH, L, LL)",
    folder    = "Bronze"
)

// EquipmentStatus ─────────────────────────────────────────────────────────────
.create-or-alter external table EquipmentStatus (
    event_id    : int,
    unit_id     : int,
    status      : string,
    event_time  : datetime,
    operator_id : string,
    notes       : string
)
kind = delta
(
    h@"abfss://<your-workspace-id>@onelake.dfs.fabric.microsoft.com/<your-bronze-lakehouse-id>/Tables/EquipmentStatus"
)
with
(
    docstring = "Equipment operational state change events (Running, Stopped, Fault, Maintenance)",
    folder    = "Bronze"
)

// GasQuality ──────────────────────────────────────────────────────────────────
.create-or-alter external table GasQuality (
    sample_id        : int,
    unit_id          : int,
    sample_time      : datetime,
    methane_pct      : real,
    ethane_pct       : real,
    propane_pct      : real,
    butane_pct       : real,
    nitrogen_pct     : real,
    co2_pct          : real,
    h2s_ppm          : real,
    gross_btu        : real,
    specific_gravity : real
)
kind = delta
(
    h@"abfss://<your-workspace-id>@onelake.dfs.fabric.microsoft.com/<your-bronze-lakehouse-id>/Tables/GasQuality"
)
with
(
    docstring = "Hourly gas chromatograph composition samples",
    folder    = "Bronze"
)

// Sensors (reference / lookup) ────────────────────────────────────────────────
.create-or-alter external table Sensors (
    sensor_id       : int,
    tag_id          : string,
    tag_name        : string,
    equipment_id    : int,
    parameter_type  : string,
    unit_of_measure : string,
    normal_min      : real,
    normal_max      : real,
    alarm_low       : real,
    alarm_high      : real
)
kind = delta
(
    h@"abfss://<your-workspace-id>@onelake.dfs.fabric.microsoft.com/<your-bronze-lakehouse-id>/Tables/Sensors"
)
with
(
    docstring = "Instrument tag catalog (40 sensor tags across 2 trains)",
    folder    = "Bronze"
)

// ProcessUnits (reference / lookup) ──────────────────────────────────────────
.create-or-alter external table ProcessUnits (
    unit_id        : int,
    unit_name      : string,
    unit_type      : string,
    parent_unit_id : int,
    location       : string,
    commissioned   : datetime,
    is_active      : bool
)
kind = delta
(
    h@"abfss://<your-workspace-id>@onelake.dfs.fabric.microsoft.com/<your-bronze-lakehouse-id>/Tables/ProcessUnits"
)
with
(
    docstring = "Plant equipment hierarchy (Plant → Train → Compressor / Separator / Meter)",
    folder    = "Bronze"
)

// =============================================================================
// NATIVE TABLES — for Ontology bindings and Materialized Views
//
// Fabric Ontology (Preview) does not support external tables (shortcuts) as
// data sources. Native tables are required for:
//   - Entity type bindings (tabular)
//   - Time series bindings
//   - Materialized views
//
// Ingestion strategy:
//   - SensorTelemetry: initial full load + incremental append via pipeline
//   - SensorCurrentState: materialized view (auto-updated by KQL engine)
// =============================================================================

// ── Step 1: Create native telemetry table ────────────────────────────────────
// Run once to create the table schema.
.create-or-merge table SensorTelemetry (
    reading_id : long,
    sensor_id  : int,
    ts         : datetime,
    value      : real,
    quality    : int
)
with
(
    docstring = "Native copy of SensorReadings for Ontology time series binding",
    folder    = "Silver"
)

// ── Step 2: Initial full load from shortcut ───────────────────────────────────
// Run ONCE after table creation to backfill all available history.
// Remove or comment out after initial load — use Step 3 for ongoing updates.
.set-or-append SensorTelemetry <|
external_table('SensorReadings')

// ── Step 3: Incremental append (run via pipeline every 5 min) ────────────────
// Add this as a KQL Script activity in pl-watchdog or a dedicated pipeline.
// Uses the watermark pattern to avoid duplicate ingestion.
.append SensorTelemetry <|
let last_ts = toscalar(SensorTelemetry | summarize max(ts));
external_table('SensorReadings')
| where ts > last_ts

// ── Step 4: Materialized View — current state (1 row per sensor) ─────────────
// Auto-maintained by the KQL engine whenever SensorTelemetry receives new data.
// Use this table as the entity binding source in the Ontology (key: sensor_id).
.create-or-alter materialized-view with (backfill=true) SensorCurrentState on table SensorTelemetry
{
    SensorTelemetry
    | summarize arg_max(ts, value, quality) by sensor_id
}

// ── Step 5: Enriched current state with alarm status (optional lookup) ────────
// If you need tag_name / alarm thresholds in the Ontology entity properties,
// join SensorCurrentState against the Sensors external table at query time:
//
// SensorCurrentState
// | join kind=inner (
//     external_table('Sensors')
//     | project sensor_id, tag_id, tag_name, parameter_type, unit_of_measure,
//               equipment_id, normal_min, normal_max, alarm_low, alarm_high
// ) on sensor_id
// | extend
//     alarm_status    = case(value > alarm_high, "ALARM-H",
//                            value < alarm_low,  "ALARM-L",
//                            value > normal_max, "HIGH",
//                            value < normal_min, "LOW",
//                                                "NORMAL"),
//     is_out_of_range = value > normal_max or value < normal_min
// | project sensor_id, tag_id, tag_name, parameter_type, unit_of_measure,
//           equipment_id, value = round(value, 2), alarm_status,
//           is_out_of_range, last_updated = ts
