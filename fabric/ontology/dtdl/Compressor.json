{
  "@context": "dtmi:dtdl:context;2",
  "@id": "dtmi:demo:energyrti:Compressor;1",
  "@type": "Interface",
  "displayName": "Gas Compressor",
  "description": "Reciprocating or centrifugal gas compressor within a processing train. Tracked by shaft speed, suction/discharge pressures and temperatures, and power consumption.",
  "contents": [
    {
      "@type": ["Property", "TimeSeriesId"],
      "name": "compressorId",
      "displayName": "Compressor ID",
      "description": "Unique identifier for the compressor (e.g. A-K100, B-K200)",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "compressorName",
      "displayName": "Compressor Name",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "compressorType",
      "displayName": "Compressor Type",
      "description": "Reciprocating | Centrifugal | Screw",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "nominalRpm",
      "displayName": "Nominal Shaft Speed",
      "description": "Design shaft speed in RPM",
      "schema": "double"
    },
    {
      "@type": "Property",
      "name": "nominalPowerKw",
      "displayName": "Nominal Power",
      "description": "Nameplate power rating in kW",
      "schema": "double"
    },
    {
      "@type": "Property",
      "name": "commissionedDate",
      "displayName": "Commissioned Date",
      "schema": "date",
      "writable": false
    },
    {
      "@type": "Telemetry",
      "name": "operationalStatus",
      "displayName": "Operational Status",
      "description": "Current state: Running, Stopped, Fault, Maintenance",
      "schema": "string"
    },
    {
      "@type": "Telemetry",
      "name": "suctionPressure",
      "displayName": "Suction Pressure",
      "description": "Compressor inlet pressure",
      "schema": "double",
      "unit": "bar"
    },
    {
      "@type": "Telemetry",
      "name": "dischargePressure",
      "displayName": "Discharge Pressure",
      "description": "Compressor outlet pressure",
      "schema": "double",
      "unit": "bar"
    },
    {
      "@type": "Telemetry",
      "name": "compressionRatio",
      "displayName": "Compression Ratio",
      "description": "Discharge pressure ÷ suction pressure. Normal range: 2.0 – 4.0",
      "schema": "double"
    },
    {
      "@type": "Telemetry",
      "name": "suctionTemperature",
      "displayName": "Suction Temperature",
      "schema": "double",
      "unit": "degreeCelsius"
    },
    {
      "@type": "Telemetry",
      "name": "dischargeTemperature",
      "displayName": "Discharge Temperature",
      "description": "High discharge temperature is an early indicator of valve wear or overload",
      "schema": "double",
      "unit": "degreeCelsius"
    },
    {
      "@type": "Telemetry",
      "name": "shaftSpeed",
      "displayName": "Shaft Speed",
      "schema": "double",
      "unit": "revolutionsPerMinute"
    },
    {
      "@type": "Telemetry",
      "name": "powerConsumption",
      "displayName": "Power Consumption",
      "schema": "double",
      "unit": "kilowatt"
    },
    {
      "@type": "Relationship",
      "name": "hasSensor",
      "displayName": "Has Sensor",
      "description": "Instrument tags directly associated with this compressor",
      "target": "dtmi:demo:energyrti:Sensor;1"
    }
  ]
}
