{
  "@context": "dtmi:dtdl:context;2",
  "@id": "dtmi:demo:energyrti:Train;1",
  "@type": "Interface",
  "displayName": "Processing Train",
  "description": "LP Gas processing train. Each train has a separator, multiple compressors, and a metering station.",
  "contents": [
    {
      "@type": ["Property", "TimeSeriesId"],
      "name": "trainId",
      "displayName": "Train ID",
      "description": "Unique identifier for the train (e.g. Train_A, Train_B)",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "trainName",
      "displayName": "Train Name",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "location",
      "displayName": "Physical Location",
      "description": "Physical pad or area where the train is located",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "commissionedDate",
      "displayName": "Commissioned Date",
      "schema": "date",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "compressorCount",
      "displayName": "Number of Compressors",
      "schema": "integer",
      "writable": false
    },
    {
      "@type": "Telemetry",
      "name": "operationalStatus",
      "displayName": "Operational Status",
      "description": "Current train status: Running, Stopped, Fault, Maintenance",
      "schema": "string"
    },
    {
      "@type": "Telemetry",
      "name": "exportFlow",
      "displayName": "Export Gas Flow",
      "description": "Gas flow through the train export metering station",
      "schema": "double",
      "unit": "mmscfd"
    },
    {
      "@type": "Telemetry",
      "name": "separatorInletPressure",
      "displayName": "Separator Inlet Pressure",
      "schema": "double",
      "unit": "bar"
    },
    {
      "@type": "Telemetry",
      "name": "separatorInletTemperature",
      "displayName": "Separator Inlet Temperature",
      "schema": "double",
      "unit": "degreeCelsius"
    },
    {
      "@type": "Telemetry",
      "name": "separatorLiquidLevel",
      "displayName": "Separator Liquid Level",
      "schema": "double",
      "unit": "percent"
    },
    {
      "@type": "Telemetry",
      "name": "totalTrainPower",
      "displayName": "Total Train Power Consumption",
      "description": "Sum of all compressor power in this train",
      "schema": "double",
      "unit": "kilowatt"
    },
    {
      "@type": "Telemetry",
      "name": "activeAlarmCount",
      "displayName": "Active Alarm Count",
      "description": "Unacknowledged alarms within this train",
      "schema": "integer"
    },
    {
      "@type": "Telemetry",
      "name": "methanePercent",
      "displayName": "Methane Content",
      "description": "Latest gas chromatograph methane reading",
      "schema": "double",
      "unit": "percent"
    },
    {
      "@type": "Telemetry",
      "name": "grossBtu",
      "displayName": "Gross Heating Value",
      "description": "BTU per standard cubic foot from chromatograph",
      "schema": "double"
    },
    {
      "@type": "Telemetry",
      "name": "h2sPpm",
      "displayName": "H2S Concentration",
      "description": "Hydrogen sulfide content in parts per million",
      "schema": "double"
    },
    {
      "@type": "Relationship",
      "name": "hasCompressor",
      "displayName": "Has Compressor",
      "description": "A train contains one or more gas compressors",
      "target": "dtmi:demo:energyrti:Compressor;1",
      "minMultiplicity": 1,
      "maxMultiplicity": 6
    },
    {
      "@type": "Relationship",
      "name": "hasSensor",
      "displayName": "Has Sensor",
      "description": "Direct sensor tags on the train-level instruments (separator, metering)",
      "target": "dtmi:demo:energyrti:Sensor;1"
    }
  ]
}
