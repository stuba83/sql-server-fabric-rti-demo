{
  "@context": "dtmi:dtdl:context;2",
  "@id": "dtmi:demo:energyrti:GasPlant;1",
  "@type": "Interface",
  "displayName": "LP Gas Plant",
  "description": "Root interface representing the LP Gas processing plant. Contains all processing trains.",
  "contents": [
    {
      "@type": "Property",
      "name": "plantName",
      "displayName": "Plant Name",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "location",
      "displayName": "Location",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "totalTrains",
      "displayName": "Total Trains",
      "description": "Number of processing trains in the plant",
      "schema": "integer",
      "writable": false
    },
    {
      "@type": "Property",
      "name": "commissionedDate",
      "displayName": "Commissioned Date",
      "schema": "date",
      "writable": false
    },
    {
      "@type": ["Property", "TimeSeriesId"],
      "name": "plantId",
      "displayName": "Plant ID",
      "schema": "string",
      "writable": false
    },
    {
      "@type": "Telemetry",
      "name": "totalExportFlow",
      "displayName": "Total Export Gas Flow",
      "description": "Sum of all train export flows",
      "schema": "double",
      "unit": "mmscfd"
    },
    {
      "@type": "Telemetry",
      "name": "totalPowerConsumption",
      "displayName": "Total Power Consumption",
      "description": "Sum of all compressor power across all trains",
      "schema": "double",
      "unit": "kilowatt"
    },
    {
      "@type": "Telemetry",
      "name": "activeAlarmCount",
      "displayName": "Active Alarm Count",
      "description": "Number of unacknowledged alarms across the plant",
      "schema": "integer"
    },
    {
      "@type": "Relationship",
      "name": "contains",
      "displayName": "Contains Train",
      "description": "A plant contains one or more processing trains",
      "target": "dtmi:demo:energyrti:Train;1",
      "minMultiplicity": 1,
      "maxMultiplicity": 10
    }
  ]
}
